<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="800dp"
    android:layout_height="wrap_content"
    android:background="@color/bg_general"
    android:orientation="vertical"
    android:padding="20dp">

    <ImageButton
        android:id="@+id/CloseButton"
        android:layout_width="24dp"
        android:layout_height="24dp"
        android:background="@android:color/transparent"
        android:fontFamily="@font/open_sans"
        android:src="@drawable/baseline_close_24"
        android:scaleType="fitCenter"
        android:contentDescription="Close"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <TextView
        android:id="@+id/ScouterNameTitle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="34dp"
        android:fontFamily="@font/futura_medium_condensed_bt"
        android:text="@string/ScouterNameID"
        android:textColor="@color/sky"
        android:textSize="@dimen/subheader_text_size"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />
    <TextView
        android:id="@+id/ScouterNameQR"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginStart="12dp"
        android:minWidth="100dp"
        android:fontFamily="@font/open_sans"
        android:textColor="@color/cloud"
        android:textSize="@dimen/button_text_size"
        app:layout_constraintStart_toEndOf="@id/ScouterNameTitle"
        app:layout_constraintTop_toTopOf="@id/ScouterNameTitle" />

    <TextView
        android:id="@+id/MatchNumberTitle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="5dp"
        android:fontFamily="@font/futura_medium_condensed_bt"
        android:text="@string/MatchNumberID"
        android:textColor="@color/sky"
        android:textSize="@dimen/subheader_text_size"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/ScouterNameTitle" />

    <TextView
        android:id="@+id/MatchNumberQR"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginStart="12dp"
        android:minWidth="100dp"
        android:fontFamily="@font/open_sans"
        android:textColor="@color/cloud"
        android:textSize="@dimen/button_text_size"
        app:layout_constraintStart_toEndOf="@id/MatchNumberTitle"
        app:layout_constraintTop_toTopOf="@id/MatchNumberTitle" />

    <TextView
        android:id="@+id/TeamNumberTitle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="5dp"
        android:fontFamily="@font/futura_medium_condensed_bt"
        android:text="@string/TeamNumberID"
        android:textColor="@color/sky"
        android:textSize="@dimen/subheader_text_size"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/MatchNumberTitle" />
    <TextView
        android:id="@+id/TeamNumberQR"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginStart="12dp"
        android:minWidth="100dp"
        android:fontFamily="@font/open_sans"
        android:textColor="@color/cloud"
        android:textSize="@dimen/button_text_size"
        app:layout_constraintStart_toEndOf="@id/TeamNumberTitle"
        app:layout_constraintTop_toTopOf="@id/TeamNumberTitle" />

    <ImageView
        android:id="@+id/imageView"
        android:layout_width="400dp"
        android:layout_height="400dp"
        android:layout_marginEnd="10dp"
        android:layout_marginTop="34dp"
        android:contentDescription="@string/QRCode"
        app:layout_constraintEnd_toStartOf="@id/CloseButton"
        app:layout_constraintTop_toTopOf="parent"
        app:srcCompat="@color/charcoal" />

    <View
        android:id="@+id/view2"
        android:layout_width="match_parent"
        android:layout_height="2dp"
        android:layout_marginVertical="15dp"
        android:background="@color/ocean"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/imageView" />

    <Button
        android:id="@+id/GoBackButton"
        android:layout_width="match_parent"
        android:layout_height="@dimen/large_button_height"
        android:layout_marginTop="15dp"
        android:background="@drawable/button_large_states"
        android:fontFamily="@font/open_sans"
        android:text="@string/SetupNext"
        android:textColor="@drawable/text_states"
        android:textSize="@dimen/button_text_size"
        app:icon="@drawable/start_button_symbol_states"
        app:iconGravity="textStart"
        app:iconSize="26dp"
        app:iconTint="@null"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/view2" />

</androidx.constraintlayout.widget.ConstraintLayout>