<selector xmlns:android="http://schemas.android.com/apk/res/android">
    <!-- active -->
    <item android:state_enabled="true" android:state_selected="true"
        android:drawable="@drawable/toggle_red_active" />
    <!-- pressed -->
    <item android:state_pressed="true">
        <shape xmlns:android="http://schemas.android.com/apk/res/android"
            android:shape="rectangle">
            <size android:height="@dimen/square_toggle_length"
                android:width="@dimen/square_toggle_length" />
            <corners
                android:bottomRightRadius="0dp"
                android:bottomLeftRadius="5dp"
                android:topLeftRadius="5dp"
                android:topRightRadius="0dp"/>
            <solid android:color="@color/dark_red"/>
            <padding
                android:bottom="5dp"
                android:left="10dp"
                android:right="10dp"
                android:top="5dp"/>
        </shape>
    </item>>
    <!-- default -->
    <item android:drawable="@drawable/toggle_right_default" />
</selector>