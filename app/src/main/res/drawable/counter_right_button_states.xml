<?xml version="1.0" encoding="utf-8" ?>
<selector xmlns:android="http://schemas.android.com/apk/res/android">
    <!-- disabled -->
    <item
        android:state_enabled="false"
        android:state_checked="false"
        android:state_pressed="false">
        <shape android:shape="rectangle">
            <solid android:color="@color/night"/>
            <corners android:topRightRadius="5dp" android:bottomRightRadius="5dp" />
        </shape>
    </item>
    <!-- default -->
    <item
        android:state_enabled="true"
        android:state_selected="false"
        android:state_pressed="false">
        <shape android:shape="rectangle">
            <solid android:color="@color/ocean"/>
            <corners android:topRightRadius="5dp" android:bottomRightRadius="5dp" />
        </shape>
    </item>
    <!-- focused -->
    <item
        android:state_enabled="true"
        android:state_focused="true">
        <shape android:shape="rectangle">
            <solid android:color="@color/afterdark"/>
            <corners android:topRightRadius="5dp" android:bottomRightRadius="5dp" />
        </shape>
    </item>
    <!-- pressed -->
    <item
        android:state_enabled="true"
        android:state_pressed="true">
        <shape android:shape="rectangle">
            <solid android:color="@color/melon"/>
            <corners android:topRightRadius="5dp" android:bottomRightRadius="5dp" />
        </shape>
    </item>
    <!-- checked/active -->
    <item
        android:state_enabled="true"
        android:state_selected="true">
        <shape android:shape="rectangle">
            <solid android:color="@color/melon"/>
            <corners android:topRightRadius="5dp" android:bottomRightRadius="5dp" />
        </shape>
    </item>
    <!-- checked/active and disabled -->
    <item
        android:state_enabled="false"
        android:state_selected="true">
        <shape android:shape="rectangle">
            <solid android:color="@color/rust"/>
            <corners android:topRightRadius="5dp" android:bottomRightRadius="5dp" />
        </shape>
    </item>
</selector>
